# PostgreSQL
POSTGRES_DB=calculator
POSTGRES_USER=calculator
POSTGRES_PASSWORD=strong_password_123

# JWT
JWT_SECRET=your-256-bit-secret-key-for-jwt-token-generation-2024
JWT_EXPIRATION=86400000

# Email (для уведомлений)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password

# API Лиман Про
LIMAN_PRO_API_URL=https://api.liman.pro/v1
LIMAN_PRO_API_KEY=your-api-key-here

# Логирование
LOGGING_LEVEL=INFO

# Профиль Spring
SPRING_PROFILES_ACTIVE=prod